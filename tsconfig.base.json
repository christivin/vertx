{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "baseUrl": ".",
    "paths": {
      "@vertx/api": ["packages/api/src/index.ts"],
      "@vertx/domain": ["packages/domain/src/index.ts"],
      "@vertx/openclaw-adapter": ["packages/openclaw-adapter/src/index.ts"],
      "@vertx/realtime-gateway-contracts": [
        "packages/realtime-gateway-contracts/src/index.ts"
      ],
      "@vertx/contracts": ["packages/contracts/src/index.ts"]
    }
  }
}
