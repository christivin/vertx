{
  "name": "vertx",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @vertx/realtime-gateway-server build && pnpm --filter @vertx/web build",
    "dev:realtime": "pnpm --filter @vertx/realtime-gateway-server dev",
    "start:realtime": "pnpm --filter @vertx/realtime-gateway-server start",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.33.0"
}
